target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Node (if UI ever uses frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

