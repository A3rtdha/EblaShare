# =============================================================================
# EBLASHARE PROJECT - GLOBAL GITIGNORE
# =============================================================================
# P2P file sync app | Java 17 | Gradle | JavaFX
# EblaShare — .gitignore
# Stack: Java 17 / Gradle (Kotlin DSL) / JavaFX
# IDE:   Cursor (VS Code fork)
# OS:    Windows + Linux + macOS
# =============================================================================

# -----------------------------------------------------------------------------
# Project-specific artifacts
# -----------------------------------------------------------------------------
# Magic folder - user's shared files (DO NOT COMMIT)
eblashare/

# Application logs and temp files
*.log
logs/
*.tmp
*.temp
~$*
*.swp
*.swo
*~

# APM reports (генерируются программой, не коммитим)
*.html

# Config с личными данными пользователя
config.yml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Gradle Build System
# -----------------------------------------------------------------------------
# ── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Keep Gradle Wrapper (required for reproducible builds)
**/build/
out/
**/out/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
.gradletasknamecache

# Gradle cache and local properties (may contain secrets)
.gradle/gradle.properties
.gradle/caches/
.gradle/daemon/
.gradle/native/

# -----------------------------------------------------------------------------
# Java Compiled Files
# -----------------------------------------------------------------------------
# ── Java ─────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# JetBrains IDEs (IntelliJ, Android Studio, etc.)
# -----------------------------------------------------------------------------
# User-specific configuration
# ── Cursor / VS Code ─────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.cursor/*
!.cursor/rules/
*.code-workspace
.history/

# ── IntelliJ IDEA (если вдруг) ───────────────────────────────────────────────
.idea/

# Compiled output
out/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Native builds
.externalNativeBuild/
cmake-build-*/

