    {
      "label": "Docker: Down",
      "type": "shell",
      "command": "make down",
      "group": "none",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "Docker: Logs",
      "type": "shell",
      "command": "make logs",
      "group": "none",
